# Chave da OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Modelo padrão (pode ser trocado por sessão com /model)
KCODE_MODEL=anthropic/claude-3.5-haiku

# Modelo mais forte para tarefas pesadas (/model strong)
KCODE_MODEL_STRONG=anthropic/claude-3.5-sonnet

# Opcional: fallback gratuito
KCODE_MODEL_FREE=deepseek/deepseek-chat:free

# Hosts SSH permitidos (separados por vírgula)
SSH_ALLOWED_HOSTS=vps1.exemplo.com,vps2.exemplo.com

# Usuário SSH padrão
SSH_DEFAULT_USER=deploy

# Caminho da chave privada SSH
SSH_KEY_PATH=~/.ssh/id_rsa

# Sites de deploy conhecidos (JSON)
# {"nome": {"host": "vps1.exemplo.com", "path": "/var/www/nome", "cmd": "git pull && pm2 restart nome"}}
DEPLOY_SITES={}
